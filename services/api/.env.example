APP_ENV=production
API_HOST=0.0.0.0
API_PORT=8000
PORT=8000

# 公网部署后可以填自己的域名，例如 https://api.example.com
PUBLIC_BASE_URL=

# 如果未来有 Web 管理台，再把前端域名填进来；多个地址用逗号分隔
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_CREDENTIALS=false

# 云端暂时建议先用 mock，等你把风格层服务化后再切 openclaw
STYLE_MODE=mock
OPENCLAW_AGENT=main
OPENCLAW_TIMEOUT=90

# 如果你有真实录取数据，把路径换掉
ADMISSIONS_DATA_FILE=
